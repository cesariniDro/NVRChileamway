<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050508">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

    <!-- VLCVideoLayout — renderiza H.264 y H.265 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000000">

      <org.videolan.libvlc.util.VLCVideoLayout
          android:id="@+id/vlc_layout"
          android:layout_width="match_parent"
          android:layout_height="match_parent"/>

      <TextView
          android:id="@+id/tv_no_signal"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:text="SIN SEÑAL — Toca CONECTAR"
          android:textColor="#333355"
          android:fontFamily="monospace"
          android:textSize="11sp"/>
    </FrameLayout>

    <!-- Status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#0b0b12"
        android:paddingHorizontal="14dp"
        android:gravity="center_vertical">

      <View
          android:id="@+id/status_dot"
          android:layout_width="9dp"
          android:layout_height="9dp"
          android:background="@drawable/dot_red"/>

      <TextView
          android:id="@+id/tv_status"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="8dp"
          android:text="DESCONECTADO"
          android:textColor="#ff3b3b"
          android:fontFamily="monospace"
          android:textSize="10sp"/>

      <TextView
          android:id="@+id/rec_indicator"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="● REC"
          android:textColor="#ff3b3b"
          android:fontFamily="monospace"
          android:textSize="10sp"
          android:visibility="gone"/>
    </LinearLayout>

    <!-- URL -->
    <TextView
        android:id="@+id/tv_rtsp_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0b0b12"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:textColor="#333355"
        android:fontFamily="monospace"
        android:textSize="9sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="1dp"/>

    <!-- Conectar + Snap -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

      <Button
          android:id="@+id/btn_connect"
          android:layout_width="0dp"
          android:layout_height="54dp"
          android:layout_weight="1"
          android:layout_marginEnd="8dp"
          android:text="▶  CONECTAR"
          android:textColor="#00e676"
          android:fontFamily="monospace"
          android:textSize="11sp"
          android:backgroundTint="#0b1a0f"/>

      <Button
          android:id="@+id/btn_snap"
          android:layout_width="54dp"
          android:layout_height="54dp"
          android:text="📸"
          android:textSize="20sp"
          android:backgroundTint="#161622"/>
    </LinearLayout>

    <!-- Grabar + NVR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="16dp">

      <Button
          android:id="@+id/btn_record"
          android:layout_width="0dp"
          android:layout_height="54dp"
          android:layout_weight="1"
          android:layout_marginEnd="8dp"
          android:text="⏺  GRABAR"
          android:textColor="#ff3b3b"
          android:fontFamily="monospace"
          android:textSize="11sp"
          android:backgroundTint="#1a0808"/>

      <Button
          android:id="@+id/btn_nvr"
          android:layout_width="0dp"
          android:layout_height="54dp"
          android:layout_weight="1"
          android:text="🔄  NVR AUTO"
          android:textColor="#4f8ef7"
          android:fontFamily="monospace"
          android:textSize="11sp"
          android:backgroundTint="#080e1a"/>
    </LinearLayout>

  </LinearLayout>
</ScrollView>
